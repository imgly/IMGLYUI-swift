      }
    },
    "ly_img_engine_error_encode_cancelled_by_block_error" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Element in Ihrem Design konnte nicht exportiert werden. Bitte überprüfen Sie Ihr Design und versuchen Sie es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "An element in your design couldn't be exported. Please review your design and try again."
          }
        }
      }
    },
    "ly_img_engine_error_encode_export_failed" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Exportieren ist etwas schiefgelaufen. Bitte versuchen Sie es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Something went wrong while exporting. Please try again."
          }
        }
      }
    },
    "ly_img_engine_error_encode_gpu_lost_generic" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihrem Gerät sind während des Exports die Grafikressourcen ausgegangen. Versuchen Sie, mit einer niedrigeren Auflösung zu exportieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your device ran out of graphics resources during export. Try exporting at a lower resolution."
          }
        }
      }
    },
    "ly_img_engine_error_encode_gpu_lost_pdf" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihrem Gerät sind beim PDF-Export die Grafikressourcen ausgegangen. Ihr Design enthält möglicherweise Elemente, die die Fähigkeiten Ihres Geräts übersteigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your device ran out of graphics resources while exporting the PDF. Your design may contain elements that exceed your device's capabilities."
          }
        }
      }
    },
    "ly_img_engine_error_encode_gpu_lost_svg" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihrem Gerät sind während des Exports die Grafikressourcen ausgegangen. Versuchen Sie, die Größe großer Bilder in Ihrem Design zu reduzieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your device ran out of graphics resources while exporting. Try reducing the size of large images in your design."
          }
        }
      }
    },
    "ly_img_engine_error_encode_insufficient_resources" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr Gerät verfügt nicht über genügend Ressourcen für den Export. Versuchen Sie, mit einer niedrigeren Auflösung zu exportieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your device doesn't have enough resources to export. Try exporting at a lower resolution."
          }
        }
      }
    },
    "ly_img_engine_error_encode_not_all_resources_loaded" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Einige Inhalte Ihres Designs waren noch nicht vollständig geladen. Warten Sie, bis alles geladen ist, und versuchen Sie es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Some content in your design hadn't finished loading. Please wait for everything to load, then try again."
          }
        }
      }
    },
    "ly_img_engine_error_encode_output_size_exceeds_max" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Exportgröße von {{width}}x{{height}} px ist größer als von diesem Gerät unterstützt (max. {{maxSize}}). Versuchen Sie, mit einer kleineren Größe zu exportieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The export size of {{width}}x{{height}} px is larger than this device supports (max {{maxSize}}). Try exporting at a smaller size."
          }
        }
      }
    },
    "ly_img_engine_error_encode_output_size_insufficient_resources" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Export mit {{width}}x{{height}} nicht möglich. Ihr Gerät verfügt nicht über genügend Ressourcen. Versuchen Sie eine niedrigere Auflösung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Couldn't export at {{width}}x{{height}}. Your device doesn't have enough resources. Try a lower resolution."
          }
        }
      }
    },
    "ly_img_engine_error_encode_pdf_render_size_exceeds_max" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die PDF-Rendergröße von {{width}}x{{height}} px (bei {{dpi}} DPI) übersteigt die von diesem Gerät unterstützte Größe (max. {{maxSize}}). Verringern Sie die DPI oder die Exportgröße."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The PDF render size of {{width}}x{{height}} px (at {{dpi}} DPI) exceeds what this device supports (max {{maxSize}}). Try lowering the DPI or the export size."
          }
        }
      }
    },
    "ly_img_engine_error_encode_resource_load_failed_with_reason" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eine Datei in Ihrem Design konnte nicht geladen werden, daher wurde der Export abgebrochen. Stellen Sie sicher, dass alle Assets verfügbar sind, und versuchen Sie es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A file in your design couldn't be loaded, so the export was stopped. Check that all assets are available and try again."
          }
        }
      }
    },
